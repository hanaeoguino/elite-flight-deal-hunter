# OpenAI
OPENAI_API_KEY=your-openai-api-key-here

# Amadeus API (https://developers.amadeus.com — free test account)
AMADEUS_API_KEY=your-amadeus-api-key
AMADEUS_API_SECRET=your-amadeus-api-secret
AMADEUS_ENV=test  # set to "production" for live data

# SerpAPI — Google Flights (https://serpapi.com)
SERPAPI_KEY=your-serpapi-key

# Kiwi / Tequila API (https://tequila.kiwi.com)
KIWI_API_KEY=your-kiwi-api-key

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Email Notifications (Gmail — use App Password, not your login password)
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password
EMAIL_RECIPIENT=your-email@gmail.com
